.container {
  padding-bottom: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}
.seats-map {
  width: 100%;
  margin-top: 20rpx;
}
.select-area {
  background: #fff;
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}
.row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.row text {
  width: 100rpx;
  font-size: 32rpx;
  color: #333;
}
.picker {
  flex: 1;
  border: 1rpx solid #ddd;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}
.selected-info {
  margin: 30rpx;
  padding: 20rpx;
  background: #f0f9eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #07c160;
  text-align: center;
}
button[disabled] {
  opacity: 0.5;
}