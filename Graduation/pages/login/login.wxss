/* pages/login/login.wxss */
.login {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 50rpx;
  background-color: #fff;
  min-height: 100vh;
}
.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}
.desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}
.login-btn {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}
.protocol {
  font-size: 24rpx;
  color: #999;
  position: fixed;
  bottom: 50rpx;
}
.link {
  color: #07c160;
}