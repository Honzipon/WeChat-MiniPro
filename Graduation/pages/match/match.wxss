/* pages/match/match.wxss */
.match-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.date-scroll {
  background-color: #fff;
  padding: 20rpx 0;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
}
.date-list {
  display: inline-flex;
  padding: 0 20rpx;
}
.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 20rpx;
  padding: 10rpx 0;
  border-bottom: 4rpx solid transparent;
}
.date-item.active {
  border-bottom-color: #07c160;
  color: #07c160;
}
.weekday {
  font-size: 28rpx;
}
.day {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 5rpx;
}
.match-list {
  padding: 20rpx;
}
.match-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.match-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}
.match-teams {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 30rpx 0;
}
.team {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}
.team-logo {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}
.team-name {
  font-size: 28rpx;
  font-weight: 500;
}
.vs {
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
}
.match-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}
.price {
  color: #f00;
  font-weight: bold;
}
.loading, .no-more, .empty {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}