<view class="orders">
  <view class="tabs">
    <view class="tab {{status == '' ? 'active' : ''}}" bindtap="changeTab" data-status="">全部</view>
    <view class="tab {{status == '0' ? 'active' : ''}}" bindtap="changeTab" data-status="0">待支付</view>
    <view class="tab {{status == '1' ? 'active' : ''}}" bindtap="changeTab" data-status="1">已支付</view>
    <view class="tab {{status == '2' ? 'active' : ''}}" bindtap="changeTab" data-status="2">已完成</view>
    <view class="tab {{status == '3' ? 'active' : ''}}" bindtap="changeTab" data-status="3">已取消</view>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="orderNo" bindtap="goToDetail" data-orderno="{{item.orderNo}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status">{{item.statusText}}</text>
      </view>
      <view class="order-content">
        <image src="{{item.match.poster}}" mode="aspectFill" class="match-poster"></image>
        <view class="order-info">
          <view class="match-name">{{item.match.homeTeam}} vs {{item.match.awayTeam}}</view>
          <view class="match-time">{{item.match.matchTime}}</view>
          <view class="seat-info">{{item.seatDesc}}</view>
        </view>
      </view>
      <view class="order-footer">
        <text class="total">共{{item.seatCount}}张 实付 ¥{{item.totalAmount}}</text>
        <button size="mini" wx:if="{{item.status == 0}}" bindtap="payOrder" data-orderno="{{item.orderNo}}" catchtap>去支付</button>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && orders.length > 0}}">没有更多了</view>
  <view class="empty" wx:if="{{!loading && orders.length == 0}}">暂无订单</view>
</view>