<view class="user">
  <view class="profile" wx:if="{{userInfo}}">
    <image src="{{userInfo.avatarUrl}}" class="avatar" mode="aspectFill"></image>
    <view class="info">
      <text class="nickname">{{userInfo.nickName}}</text>
      <text class="phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
      <text class="phone" wx:else>未绑定手机号</text>
    </view>
  </view>

  <view class="stats">
    <view class="stat-item" bindtap="goToOrders">
      <text class="num">{{stats.orderCount}}</text>
      <text class="label">订单</text>
    </view>
    <view class="stat-item" bindtap="goToFavorites">
      <text class="num">{{stats.favoriteCount}}</text>
      <text class="label">收藏</text>
    </view>
    <view class="stat-item" bindtap="goToCoupons">
      <text class="num">{{stats.couponCount}}</text>
      <text class="label">优惠券</text>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goToOrders">
      <text class="icon">📋</text>
      <text class="text">我的订单</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <text class="icon">❤️</text>
      <text class="text">我的收藏</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCoupons">
      <text class="icon">🎫</text>
      <text class="text">优惠券</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="icon">⚙️</text>
      <text class="text">设置</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="icon">ℹ️</text>
      <text class="text">关于我们</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout" bindtap="logout">退出登录</button>
</view>